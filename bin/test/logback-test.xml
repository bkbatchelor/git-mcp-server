<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Test-specific Logback configuration -->
    <!-- Simplified configuration without custom appenders for testing -->
    
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
    
    <!-- Application loggers -->
    <logger name="io.sandboxdev.gitmcp" level="DEBUG"/>
    
    <!-- Reduce Spring Boot noise in tests -->
    <logger name="org.springframework.boot" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.eclipse.jgit" level="WARN"/>
</configuration>