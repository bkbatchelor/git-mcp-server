# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout
*.java text
*.xml text
*.yml text
*.yaml text
*.properties text
*.md text
*.txt text
*.json text
*.sh text eol=lf
*.bat text eol=crlf

# Declare files that will always have CRLF line endings on checkout
*.cmd text eol=crlf

# Declare files that will always have LF line endings on checkout
*.sh text eol=lf

# Denote all files that are truly binary and should not be modified
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.gz binary

# Maven wrapper should always use LF
mvnw text eol=lf
mvnw.cmd text eol=crlf

# IDE files
*.iml text
*.ipr text
*.iws text
.project text
.classpath text

# Log files should use system default
*.log text