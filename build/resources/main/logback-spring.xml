<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 
    CRITICAL: This configuration ensures System.out is reserved for MCP protocol messages
    All application logs are redirected to System.err to prevent protocol corruption
    -->
    
    <!-- Console appender that writes to System.err -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- Custom MCP appender for forwarding logs to MCP Host -->
    <appender name="MCP_BRIDGE" class="io.sandboxdev.gitmcp.config.McpLogAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- Root logger configuration -->
    <root level="INFO">
        <appender-ref ref="STDERR" />
        <appender-ref ref="MCP_BRIDGE" />
    </root>
    
    <!-- Application-specific logging levels -->
    <logger name="io.sandboxdev.gitmcp" level="DEBUG" additivity="false">
        <appender-ref ref="STDERR" />
        <appender-ref ref="MCP_BRIDGE" />
    </logger>
    
    <!-- Spring Boot startup logs to stderr -->
    <logger name="org.springframework.boot" level="INFO" additivity="false">
        <appender-ref ref="STDERR" />
    </logger>
    
    <!-- JGit logs -->
    <logger name="org.eclipse.jgit" level="WARN" additivity="false">
        <appender-ref ref="STDERR" />
        <appender-ref ref="MCP_BRIDGE" />
    </logger>
    
    <!-- Suppress noisy Spring logs -->
    <logger name="org.springframework.web" level="WARN" />
    <logger name="org.springframework.security" level="WARN" />
</configuration>