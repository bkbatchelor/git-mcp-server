{
  "mcpServers": {
    "git": {
      "command": "java",
      "args": [
        "-Djava.awt.headless=true",
        "-jar",
        "target/git-mcp-server-1.0.0.jar"
      ],
      "env": {
        "LOG_LEVEL": "INFO",
        "SPRING_PROFILES_ACTIVE": "prod"
      },
      "disabled": false,
      "autoApprove": [
        "get-status",
        "get-history",
        "get-commit-details",
        "get-current-branch",
        "list-branches",
        "list-remotes",
        "get-diff",
        "get-file-contents",
        "generate-commit-message"
      ]
    }
  }
}