{
  "mcpServers": {
    "git-mcp-server": {
      "command": "uvx",
      "args": ["git-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "INFO"
      },
      "disabled": false,
      "autoApprove": [
        "get-status",
        "get-history",
        "get-commit-details",
        "get-current-branch",
        "list-branches",
        "list-remotes",
        "get-diff",
        "get-file-contents",
        "generate-commit-message"
      ]
    }
  }
}