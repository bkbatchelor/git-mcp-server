<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 
    CRITICAL: MCP Protocol Compliance
    System.out is reserved exclusively for JSON-RPC protocol messages.
    All application logs MUST be redirected to System.err to prevent protocol corruption.
    -->
    
    <!-- Console Appender - Redirected to System.err -->
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    
    <!-- MCP Notification Appender - Forward logs to IDE via MCP notifications -->
    <appender name="MCP_NOTIFICATION" class="io.sandboxdev.gitmcp.logging.McpNotificationAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg</pattern>
        </encoder>
        <!-- Only forward INFO and above to prevent spam -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>
    
    <!-- File Appender for Development -->
    <springProfile name="dev">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/git-mcp-server.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/git-mcp-server.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
    </springProfile>
    
    <!-- Root Logger Configuration -->
    <root level="INFO">
        <appender-ref ref="STDERR"/>
        <springProfile name="dev">
            <appender-ref ref="FILE"/>
        </springProfile>
        <!-- MCP Notification appender will be added when implemented -->
    </root>
    
    <!-- Spring Boot specific loggers -->
    <logger name="org.springframework.boot" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>
    
    <!-- Spring AI loggers -->
    <logger name="org.springframework.ai" level="INFO"/>
    
    <!-- JGit loggers -->
    <logger name="org.eclipse.jgit" level="WARN"/>
    
    <!-- Application loggers -->
    <logger name="io.sandboxdev.gitmcp" level="INFO"/>
    
    <!-- Development Profile - More verbose logging -->
    <springProfile name="dev">
        <logger name="io.sandboxdev.gitmcp" level="DEBUG"/>
        <logger name="org.springframework.ai" level="DEBUG"/>
    </springProfile>
    
    <!-- Production Profile - Minimal logging -->
    <springProfile name="prod">
        <root level="WARN"/>
        <logger name="io.sandboxdev.gitmcp" level="INFO"/>
    </springProfile>
</configuration>